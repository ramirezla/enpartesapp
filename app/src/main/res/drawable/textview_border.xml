<?xml version="1.0" encoding="utf-8"?><shape xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    tools:ignore="ExtraText">
    <solid android:color="@android:color/white" />  <!-- Background color of the box -->
    <stroke
        android:width="2dp"
        android:color="@android:color/black" />    <!-- Border color -->
    <padding
        android:left="10dp"
        android:top="10dp"
        android:right="10dp"
        android:bottom="10dp" />                  <!-- Paddinginside the box -->
    <corners android:radius="5dp" />              <!-- Corner radius -->
</shape>