<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/fragment_consultasabiertas"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:name="ConsAbiEmailAddress" app:argType="string"
    tools:context=".ui.consultasabiertas.ConsultasabiertasFragment">

    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="409dp"
        android:layout_height="0dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="272dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="MissingConstraints">

        <ImageView
            android:id="@+id/logo_enpartes_ca"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="end"
            android:layout_marginEnd="100dp"
            android:layout_weight="1"
            android:clickable="false"
            android:contentDescription="@string/descripcion_logo_enpartes"
            android:src="@drawable/logo_enpartes" />

        <TextView
            android:id="@+id/ConsAbiEmailAddress"
            android:layout_width="327dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:autofillHints="@string/hint_cuenta_usuario"
            android:contentDescription="@string/hint_cuenta_usuario"
            android:ems="10" />
    </LinearLayout>

    <TextView
        android:id="@+id/textConsultasabiertas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:textAlignment="center"
        android:textSize="20sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>